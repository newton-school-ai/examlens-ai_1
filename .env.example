# Database
DATABASE_URL=postgresql://localhost/examlens_dev

# LLM (Groq is free - recommended)
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-70b-versatile

# OCR Configuration
OCR_PRIMARY=tesseract
OCR_FALLBACK=easyocr
OCR_CONFIDENCE_THRESHOLD=0.7
OCR_LANGUAGES=en,hi

# Handwritten OCR
TROCR_MODEL=microsoft/trocr-base-handwritten

# Math Extraction
MATH_EXTRACTOR=pix2tex

# Layout Detection
LAYOUT_MODEL=yolov8
LAYOUT_CONFIDENCE=0.5

# Scraper
SCRAPER_RATE_LIMIT=2
SCRAPER_MAX_PAGES=50

# Answer Generation
ANSWER_MAX_TOKENS=2000
ANSWER_TEMPERATURE=0.3
VERIFICATION_SOURCES=2

# Google OAuth (get from console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# JWT
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Server
HOST=0.0.0.0
PORT=8000
